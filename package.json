{
  "name": "taskflow",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @taskflow/web dev",
    "dev:backend": "pnpm --filter @taskflow/backend dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,vue,js,json,md,yml,yaml}\"",
    "test": "turbo run test -- --passWithNoTests",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "pnpm --filter @taskflow/backend prisma:migrate",
    "db:generate": "pnpm --filter @taskflow/backend prisma:generate",
    "db:reset": "pnpm --filter @taskflow/backend exec prisma migrate reset --force"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@swc/core",
      "esbuild",
      "@parcel/watcher",
      "bcrypt"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vue-eslint-parser": "^9.4.3"
  }
}
