// TaskFlow — schéma Prisma (E0)
// User → List → Task. Ownership tâche : Task → List → User (pas de userId direct sur Task).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  firstname String
  lastname  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  lists List[]
}

model List {
  id        String   @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  tasks Task[]

  @@unique([name, userId])
}

model Task {
  id               String    @id @default(uuid())
  shortDescription String
  longDescription  String?
  dueDate          DateTime
  completedAt      DateTime?
  listId           String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}
