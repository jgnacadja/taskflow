# ─── Général ───────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow

# URL utilisée par Prisma / le backend.
# host = "postgres" (nom du service docker-compose), "localhost" hors Docker.
DATABASE_URL=postgresql://taskflow:taskflow@postgres:5432/taskflow?schema=public

# ─── Backend (NestJS) ──────────────────────────────────────
BACKEND_PORT=3001
# Origines autorisées par le CORS (séparées par des virgules)
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Frontend (Nuxt) ───────────────────────────────────────
NUXT_PUBLIC_API_BASE=http://localhost:3001

CORS_ORIGIN=http://localhost:3000   # liste de domaines autorisés par le CORS (séparés par des virgules)
